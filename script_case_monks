    raw_df.columns = raw_df.columns.str.strip()
    raw_df.insert(0, "Source_Row_Number", np.arange(2, len(raw_df) + 2))
    return raw_df


def build_clean_dataframes(
    raw_df: pd.DataFrame,
) -> tuple[pd.DataFrame, pd.DataFrame, pd.DataFrame, pd.DataFrame, dict[str, pd.Series]]:
    clean_df = raw_df.copy()

    clean_df["Amount_Original"] = clean_df["Amount"]
    clean_df["Total_Product_Amount_Original"] = clean_df["Total_Product_Amount"]
    clean_df["Lead_Source_Original"] = clean_df["Lead_Source"]
    clean_df["Stage_Original"] = clean_df["Stage"]
    clean_df["Lead_Office_Original"] = clean_df["Lead_Office"]

    clean_df["Lead_Source"] = normalize_series(clean_df["Lead_Source"], LEAD_SOURCE_LOOKUP)
    clean_df["Stage"] = normalize_series(clean_df["Stage"], STAGE_LOOKUP)
    clean_df["Lead_Office"] = normalize_series(clean_df["Lead_Office"], LEAD_OFFICE_LOOKUP)
    clean_df["Lead_Source_Category"] = clean_df["Lead_Source"].map(LEAD_SOURCE_CATEGORY_MAP).fillna("Unknown")

    clean_df["Amount"] = clean_df["Amount"].map(parse_number)
    clean_df["Total_Product_Amount"] = clean_df["Total_Product_Amount"].map(parse_number)
    clean_df["Created_Date"] = pd.to_datetime(clean_df["Created_Date"], errors="coerce", dayfirst=True)
    clean_df["Close_Date"] = pd.to_datetime(clean_df["Close_Date"], errors="coerce", dayfirst=True)

    issue_masks = {
        "out_of_scope": ~raw_df["Type"].isin(VALID_TYPES),
        "duplicate_rows": raw_df.duplicated(subset=["Opportunity_ID"], keep=False),
        "lead_source_issue": ~raw_df["Lead_Source"].isin(CANONICAL_LEAD_SOURCES),
        "stage_issue": ~raw_df["Stage"].isin(CANONICAL_STAGES),
        "lead_office_issue": ~raw_df["Lead_Office"].isin(CANONICAL_LEAD_OFFICES),
        "categorical_issue": (
            ~raw_df["Lead_Source"].isin(CANONICAL_LEAD_SOURCES)
            | ~raw_df["Stage"].isin(CANONICAL_STAGES)
            | ~raw_df["Lead_Office"].isin(CANONICAL_LEAD_OFFICES)
        ),
        "numeric_format_issue": (
            raw_df["Amount"].map(lambda value: isinstance(value, str))
            | raw_df["Total_Product_Amount"].map(lambda value: isinstance(value, str))
        ),
    }

    issue_masks["numeric_separator_issue"] = (
        raw_df["Amount"].astype(str).str.contains(r"[,.]", na=False)
        | raw_df["Total_Product_Amount"].astype(str).str.contains(r"[,.]", na=False)
    )

    scoped_df = clean_df.loc[~issue_masks["out_of_scope"]].copy()
    excluded_df = clean_df.loc[issue_masks["out_of_scope"]].copy()
    excluded_df.insert(1, "Exclusion_Reason", "Type fora do escopo do case")

    scoped_df["Soma_dos_Produtos"] = scoped_df.groupby("Opportunity_ID")["Total_Product_Amount"].transform(
        lambda series: series.sum(min_count=1)
    )

    issue_masks["amount_mismatch"] = (
        (~scoped_df["Stage"].isin(EARLY_STAGES))
        & scoped_df["Amount"].notna()
        & scoped_df["Soma_dos_Produtos"].notna()
        & (scoped_df["Amount"].round(2) != scoped_df["Soma_dos_Produtos"].round(2))
    )

    scoped_df["Amount_Was_Reconciled"] = (
        scoped_df["Soma_dos_Produtos"].notna()
        & scoped_df["Amount"].notna()
        & (scoped_df["Amount"].round(2) != scoped_df["Soma_dos_Produtos"].round(2))
    )

    scoped_df["Amount"] = scoped_df["Soma_dos_Produtos"].combine_first(scoped_df["Amount"])
    scoped_df["Status"] = np.where(scoped_df["Stage"].eq("Closed Won"), "Closed Won", "Open Pipeline")
    scoped_df["Opportunity_Has_Multiple_Product_Rows"] = scoped_df.duplicated(
        subset=["Opportunity_ID"], keep=False
    )

    deal_records: list[dict[str, object]] = []
    for opportunity_id, group in scoped_df.sort_values(["Opportunity_ID", "Product_Name"]).groupby("Opportunity_ID"):
        deal_records.append(
            {
                "Opportunity_ID": opportunity_id,
                "Account_ID": first_not_blank(group["Account_ID"]),
                "Account_Name": first_not_blank(group["Account_Name"]),
                "Opportunity_Owner": first_not_blank(group["Opportunity_Owner"]),
                "Opportunity_Name": first_not_blank(group["Opportunity_Name"]),
                "Type": first_not_blank(group["Type"]),
                "Stage": first_not_blank(group["Stage"]),
                "Status": first_not_blank(group["Status"]),
                "Amount": first_not_blank(group["Amount"]),
                "Amount_Currency": first_not_blank(group["Amount_Currency"]),
                "Total_Product_Amount_Sum": group["Total_Product_Amount"].sum(min_count=1),
                "Total_Product_Amount_Currency": first_not_blank(group["Total_Product_Amount_Currency"]),
                "Product_List": join_unique_values(group["Product_Name"]),
                "Product_Count": group["Product_Name"].dropna().astype(str).str.strip().replace("", np.nan).dropna().nunique(),
                "Close_Date": first_not_blank(group["Close_Date"]),
                "Created_Date": first_not_blank(group["Created_Date"]),
                "Lead_Source": first_not_blank(group["Lead_Source"]),
                "Lead_Source_Category": first_not_blank(group["Lead_Source_Category"]),
                "Lead_Office": first_not_blank(group["Lead_Office"]),
                "Stage_Duration": first_not_blank(group["Stage_Duration"]),
                "Delivery_Length_Months": first_not_blank(group["Delivery_Length_Months"]),
                "Source_Row_Count": len(group),
                "Amount_Was_Reconciled": bool(group["Amount_Was_Reconciled"].any()),
            }
        )

    deals_df = pd.DataFrame(deal_records).sort_values(["Close_Date", "Opportunity_ID"], na_position="last")

    base_product_columns = [
        "Opportunity_ID",
        "Account_ID",
        "Account_Name",
        "Opportunity_Owner",
        "Opportunity_Name",
        "Type",
        "Stage",
        "Amount",
        "Amount_Currency",
        "Total_Product_Amount",
        "Total_Product_Amount_Currency",
        "Product_Name",
        "Close_Date",
        "Created_Date",
        "Lead_Source",
        "Lead_Source_Category",
        "Lead_Office",
        "Stage_Duration",
        "Delivery_Length_Months",
    ]

    support_product_columns = [
        "Source_Row_Number",
        "Opportunity_ID",
        "Amount_Original",
        "Amount",
        "Amount_Was_Reconciled",
        "Total_Product_Amount_Original",
        "Total_Product_Amount",
        "Soma_dos_Produtos",
        "Lead_Source_Original",
        "Lead_Source",
        "Lead_Office_Original",
        "Lead_Office",
        "Stage_Original",
        "Stage",
        "Status",
        "Opportunity_Has_Multiple_Product_Rows",
    ]

    excluded_columns = [
        "Source_Row_Number",
        "Exclusion_Reason",
        "Opportunity_ID",
        "Account_ID",
        "Account_Name",
        "Opportunity_Owner",
        "Opportunity_Name",
        "Type",
        "Stage_Original",
        "Lead_Source_Original",
        "Lead_Office_Original",
        "Amount_Original",
        "Total_Product_Amount_Original",
        "Product_Name",
        "Close_Date",
        "Created_Date",
    ]

    support_product_df = scoped_df[support_product_columns].sort_values(["Opportunity_ID", "Source_Row_Number"])
    scoped_df = scoped_df[base_product_columns].sort_values(["Opportunity_ID", "Product_Name", "Close_Date"])
    excluded_df = excluded_df[excluded_columns].sort_values(["Type", "Opportunity_ID", "Source_Row_Number"])

    return scoped_df, support_product_df, deals_df, excluded_df, issue_masks


def build_report_context(
    raw_df: pd.DataFrame,
    scoped_df: pd.DataFrame,
    support_product_df: pd.DataFrame,
    deals_df: pd.DataFrame,
    excluded_df: pd.DataFrame,
    issue_masks: dict[str, pd.Series],
) -> dict[str, object]:
    duplicate_examples = (
        raw_df.loc[issue_masks["duplicate_rows"]]
        .groupby("Opportunity_ID", as_index=False)
        .agg(
            Row_Count=("Opportunity_ID", "size"),
            Type=("Type", first_not_blank),
            Products=("Product_Name", join_unique_values),
        )
        .sort_values(["Row_Count", "Opportunity_ID"], ascending=[False, True])
        .head(5)
    )

    categorical_examples_rows: list[dict[str, object]] = []
    for field_name, issue_key, corrected_column in [
        ("Lead_Source", "lead_source_issue", "Lead_Source"),
        ("Stage", "stage_issue", "Stage"),
        ("Lead_Office", "lead_office_issue", "Lead_Office"),
    ]:
        corrected_lookup = {
            "Lead_Source": LEAD_SOURCE_LOOKUP,
            "Stage": STAGE_LOOKUP,
            "Lead_Office": LEAD_OFFICE_LOOKUP,
        }[corrected_column]
        sample = raw_df.loc[issue_masks[issue_key], ["Source_Row_Number", "Opportunity_ID", field_name]].head(8)
        for row in sample.itertuples(index=False):
            categorical_examples_rows.append(
                {
                    "Source_Row_Number": row.Source_Row_Number,
                    "Opportunity_ID": row.Opportunity_ID,
                    "Campo": field_name,
                    "Valor_Original": getattr(row, field_name),
                    "Valor_Corrigido": corrected_lookup.get(normalize_token(getattr(row, field_name)), str(getattr(row, field_name)).strip()),
                }
            )

    numeric_examples = raw_df.loc[
        issue_masks["numeric_format_issue"],
        ["Source_Row_Number", "Opportunity_ID", "Amount", "Total_Product_Amount"],
    ].head(8).copy().rename(
        columns={
            "Amount": "Amount_Original",
            "Total_Product_Amount": "Total_Product_Amount_Original",
        }
    )
    numeric_examples["Amount_Corrigido"] = numeric_examples["Amount_Original"].map(parse_number)
    numeric_examples["Total_Product_Amount_Corrigido"] = numeric_examples["Total_Product_Amount_Original"].map(parse_number)

    scoped_reference = support_product_df[
        ["Opportunity_ID", "Source_Row_Number", "Amount_Original", "Amount", "Soma_dos_Produtos"]
    ].copy()
    mismatch_examples = (
        scoped_reference.loc[support_product_df["Amount_Was_Reconciled"]]
        .drop_duplicates("Opportunity_ID")
        .rename(columns={"Amount": "Amount_Corrigido"})
        .head(8)
    )

    categories = [
        {
            "slug": "escopo",
            "title": "Registros fora do escopo da análise",
            "count": int(issue_masks["out_of_scope"].sum()),
            "description": (
                "O case pede para considerar somente três tipos de oportunidade. Tudo o que estava "
                "fora dessa lista foi separado para não contaminar as análises."
            ),
            "impact": (
                f"{int(issue_masks['out_of_scope'].sum())} linhas saíram da base analítica. "
                f"Os tipos removidos foram: {', '.join(sorted(map(str, excluded_df['Type'].dropna().unique())))}."
            ),
            "fix": (
                "Mantive esses registros na aba `registros_excluidos` para auditoria e removi essas linhas "
                "da base corrigida usada nas análises."
            ),
            "examples": dataframe_to_html_table(
                excluded_df[["Source_Row_Number", "Opportunity_ID", "Type"]].head(8)
            ),
        },
        {
            "slug": "duplicidade",
            "title": "Duplicidade aparente por granularidade de produto",
            "count": int(issue_masks["duplicate_rows"].sum()),
            "description": (
                "A planilha original veio em nível de produto. Isso faz o mesmo deal aparecer em várias "
                "linhas e pode inflar contagens se a análise for feita diretamente no bruto."
            ),
            "impact": (
                f"{int(issue_masks['duplicate_rows'].sum())} linhas tinham `Opportunity_ID` repetido, "
                f"representando {raw_df.loc[issue_masks['duplicate_rows'], 'Opportunity_ID'].nunique()} oportunidades. "
                f"Depois da deduplicação analítica, a base ficou com {len(deals_df)} deals únicos."
            ),
            "fix": (
                "Mantive a visão por produto na aba `base_produto_corrigida` e criei uma aba `deals_unicos` "
                "com uma linha por oportunidade para evitar contagem em dobro."
            ),
            "examples": dataframe_to_html_table(duplicate_examples),
        },
        {
            "slug": "categoricos",
            "title": "Campos categóricos com grafia ou formatação fora do padrão",
            "count": int(issue_masks["categorical_issue"].sum()),
            "description": (
                "Havia variações de caixa alta/baixa, espaços extras, acentos, abreviações e erros de digitação "
                "em `Lead_Source`, `Stage` e `Lead_Office`. Isso quebra agrupamentos e pode dividir a mesma categoria em várias."
            ),
            "impact": (
                f"{int(issue_masks['categorical_issue'].sum())} linhas tinham pelo menos um campo categórico fora da lista canônica. "
                f"Quebra por campo: Lead_Source = {int(issue_masks['lead_source_issue'].sum())}, "
                f"Stage = {int(issue_masks['stage_issue'].sum())}, Lead_Office = {int(issue_masks['lead_office_issue'].sum())}."
            ),
            "fix": (
                "Normalizei os valores usando as listas canônicas do brief, corrigi aliases/typos e criei a coluna "
                "`Lead_Source_Category` com a taxonomia de 6 grupos pedida no case."
            ),
            "examples": dataframe_to_html_table(pd.DataFrame(categorical_examples_rows)),
        },
        {
            "slug": "numericos",
            "title": "Campos numéricos armazenados em formatos inconsistentes",
            "count": int(issue_masks["numeric_format_issue"].sum()),
            "description": (
                "Os campos monetários estavam misturando texto, números e separadores diferentes. "
                "Sem padronização, isso pode causar soma errada, ordenação incorreta e leituras equivocadas de valor."
            ),
            "impact": (
                f"{int(issue_masks['numeric_format_issue'].sum())} linhas tinham `Amount` ou `Total_Product_Amount` "
                f"salvos como texto; em {int(issue_masks['numeric_separator_issue'].sum())} delas havia vírgula ou formatação mista "
                "de milhar/decimal."
            ),
            "fix": (
                "Convertemos os dois campos para número de forma robusta, preservando casos legítimos em branco nos estágios "
                "`Opportunity Identified` e `Qualified`."
            ),
            "examples": dataframe_to_html_table(numeric_examples),
        },
        {
            "slug": "amount",
            "title": "Divergência entre `Amount` e soma dos produtos",
            "count": int(support_product_df["Amount_Was_Reconciled"].sum()),
            "description": (
                "Em alguns deals, o valor total da oportunidade não batia com a soma dos produtos. "
                "O próprio brief define que, nesses casos, a soma de `Total_Product_Amount` é a fonte da verdade."
            ),
