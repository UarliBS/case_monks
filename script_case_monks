                f"{int(support_product_df['Amount_Was_Reconciled'].sum())} linhas no escopo tinham esse problema, "
                f"equivalentes a {support_product_df.loc[support_product_df['Amount_Was_Reconciled'], 'Opportunity_ID'].nunique()} oportunidades."
            ),
            "fix": (
                "Substituí o `Amount` pelo total consolidado de produtos e sinalizei o ajuste na coluna "
                "`Amount_Was_Reconciled`."
            ),
            "examples": dataframe_to_html_table(mismatch_examples),
        },
    ]

    summary_rows = pd.DataFrame(
        [
            {"Categoria": category["title"], "Linhas_Afetadas": category["count"]}
            for category in categories
        ]
    )

    expected_nulls = scoped_df[
        scoped_df["Stage"].isin(EARLY_STAGES) & scoped_df["Amount"].isna() & scoped_df["Product_Name"].isna()
    ]

    return {
        "categories": categories,
        "summary_table": dataframe_to_html_table(summary_rows),
        "raw_rows": len(raw_df),
        "scoped_rows": len(scoped_df),
        "excluded_rows": len(excluded_df),
        "unique_deals": len(deals_df),
        "category_count": len(categories),
        "expected_null_rows": len(expected_nulls),
    }


