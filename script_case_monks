def export_workbook(
    scoped_df: pd.DataFrame,
    support_product_df: pd.DataFrame,
    deals_df: pd.DataFrame,
    excluded_df: pd.DataFrame,
) -> None:
    with pd.ExcelWriter(OUTPUT_XLSX, engine="openpyxl") as writer:
        scoped_df.to_excel(writer, sheet_name="base_produto_corrigida", index=False)
        support_product_df.to_excel(writer, sheet_name="apoio_limpeza_produto", index=False)
        deals_df.to_excel(writer, sheet_name="deals_unicos", index=False)
        excluded_df.to_excel(writer, sheet_name="registros_excluidos", index=False)

        workbook = writer.book
        money_columns = {
            "Amount",
            "Amount_Original",
            "Total_Product_Amount",
            "Total_Product_Amount_Original",
            "Soma_dos_Produtos",
            "Total_Product_Amount_Sum",
        }

        for worksheet in workbook.worksheets:
            worksheet.freeze_panes = "A2"
            worksheet.auto_filter.ref = worksheet.dimensions

            header_fill = "0F766E"
            for cell in worksheet[1]:
                cell.font = Font(bold=True, color="FFFFFF")
                cell.fill = PatternFill(fill_type="solid", fgColor=header_fill)

            for column_cells in worksheet.columns:
                header = column_cells[0].value
                max_length = max(len(str(cell.value)) if cell.value is not None else 0 for cell in column_cells)
                worksheet.column_dimensions[column_cells[0].column_letter].width = min(max(max_length + 2, 12), 38)

                if header in {"Close_Date", "Created_Date"}:
                    for cell in column_cells[1:]:
                        cell.number_format = "DD/MM/YYYY"
                elif header in money_columns:
                    for cell in column_cells[1:]:
                        cell.number_format = '#,##0.00'


def main() -> None:
    raw_df = prepare_raw_data()
    scoped_df, support_product_df, deals_df, excluded_df, issue_masks = build_clean_dataframes(raw_df)

    report_context = build_report_context(
        raw_df,
        scoped_df,
        support_product_df,
        deals_df,
        excluded_df,
        issue_masks,
    )
    report_html = render_report(report_context)

    export_workbook(scoped_df, support_product_df, deals_df, excluded_df)
    OUTPUT_HTML.write_text(report_html, encoding="utf-8")

    print("Arquivos gerados com sucesso:")
    print(f"- {OUTPUT_XLSX.name}")
    print(f"- {OUTPUT_HTML.name}")


if __name__ == "__main__":
    main()
