def normalize_series(series: pd.Series, lookup: dict[str, str]) -> pd.Series:
    def _normalize(value: object) -> object:
        if pd.isna(value):
            return np.nan
        return lookup.get(normalize_token(value), str(value).strip())

    return series.map(_normalize)


def parse_number(value: object) -> float:
    if pd.isna(value):
        return np.nan
    if isinstance(value, (int, float, np.integer, np.floating)):
        return float(value)

    text = re.sub(r"[^\d,.\-]", "", str(value).strip())
    if not text or text in {"-", ".", ","}:
        return np.nan

    if re.fullmatch(r"-?\d{1,3}(?:\.\d{3})+(?:,\d+)?", text):
        text = text.replace(".", "")
        text = text.replace(",", ".")
    elif re.fullmatch(r"-?\d{1,3}(?:,\d{3})+(?:\.\d+)?", text):
        text = text.replace(",", "")
    elif re.fullmatch(r"-?\d+,\d+", text):
        text = text.replace(",", ".")

    try:
        return float(text)
    except ValueError:
        return np.nan


def first_not_blank(series: pd.Series) -> object:
    for value in series:
        if pd.isna(value):
            continue
        if isinstance(value, str) and not value.strip():
            continue
        return value
    return np.nan


def join_unique_values(series: pd.Series) -> str:
    values: list[str] = []
    for value in series.dropna():
        text = str(value).strip()
        if text and text not in values:
            values.append(text)
    return " | ".join(values)


def format_brl_number(value: object, decimals: int = 2) -> str:
    if pd.isna(value):
        return "—"
    number = float(value)
    formatted = f"{number:,.{decimals}f}"
    return formatted.replace(",", "X").replace(".", ",").replace("X", ".")


def format_html_value(value: object, column: str) -> str:
    if pd.isna(value):
        return "—"
    if isinstance(value, pd.Timestamp):
        return value.strftime("%d/%m/%Y")
    if column in {
        "Amount",
        "Amount_Original",
        "Total_Product_Amount",
        "Total_Product_Amount_Original",
        "Soma_dos_Produtos",
        "Amount_Corrigido",
    }:
        if isinstance(value, str):
            parsed = parse_number(value)
            return html.escape(value) if pd.isna(parsed) else format_brl_number(parsed)
        return format_brl_number(value)
    if isinstance(value, (int, np.integer)):
        return str(int(value))
    if isinstance(value, (float, np.floating)):
        if float(value).is_integer():
            return str(int(value))
        return format_brl_number(value)
    return html.escape(str(value))


def dataframe_to_html_table(df: pd.DataFrame) -> str:
    if df.empty:
        return "<p class='empty-state'>Nenhum exemplo adicional foi necessário para esta categoria.</p>"

    formatted = df.copy()
    for column in formatted.columns:
        formatted[column] = formatted[column].map(lambda value: format_html_value(value, column))
    return formatted.to_html(index=False, escape=False, classes="data-table")


