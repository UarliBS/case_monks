def build_stacked_bar_chart(labels: list[str], series: dict[str, list[float]], colors: dict[str, str], title: str) -> str:
    width = 860
    height = 380
    margin_left = 72
    margin_right = 24
    margin_top = 28
    margin_bottom = 72
    plot_width = width - margin_left - margin_right
    plot_height = height - margin_top - margin_bottom
    totals = [sum(series[name][idx] for name in series) for idx in range(len(labels))]
    max_total = max(totals) if totals else 1
    max_total = max_total if max_total > 0 else 1
    bar_gap = 14
    bar_width = (plot_width - bar_gap * max(len(labels) - 1, 0)) / max(len(labels), 1)

    bars = []
    for idx, label in enumerate(labels):
        x = margin_left + idx * (bar_width + bar_gap)
        current_top = margin_top + plot_height
        total_value = totals[idx]
        for name, values in series.items():
            value = values[idx]
            segment_height = (value / max_total) * (plot_height - 12)
            y = current_top - segment_height
            tooltip = escape_attr(f"{label} | {name}: {format_currency(value)} | Total: {format_currency(total_value)}")
            bars.append(
                f'<rect x="{x:.1f}" y="{y:.1f}" width="{bar_width:.1f}" height="{segment_height:.1f}" rx="6" fill="{colors[name]}" class="interactive-shape" data-tooltip="{tooltip}" />'
            )
            current_top = y
        bars.append(
            f"""
            <text x="{x + bar_width / 2:.1f}" y="{margin_top + plot_height + 24}" text-anchor="middle" class="axis-label">{html.escape(label)}</text>
            <text x="{x + bar_width / 2:.1f}" y="{current_top - 8:.1f}" text-anchor="middle" class="value-label">{html.escape(format_currency(totals[idx]))}</text>
            """
        )

    legend = "".join(
        f"""
        <div class="legend-item">
          <span class="legend-dot" style="background:{color}"></span>
          <span>{html.escape(name)}</span>
        </div>
        """
        for name, color in colors.items()
    )

    interactive_legend = "".join(
        f"""
        <div class="legend-item interactive-card" data-tooltip="{escape_attr(name)}">
          <span class="legend-dot" style="background:{color}"></span>
          <span>{html.escape(name)}</span>
        </div>
        """
        for name, color in colors.items()
    )

    svg = f"""
    <svg viewBox="0 0 {width} {height}" class="chart-svg" role="img" aria-label="{html.escape(title)}">
      <line x1="{margin_left}" y1="{margin_top + plot_height}" x2="{width - margin_right}" y2="{margin_top + plot_height}" class="axis-line" />
      {''.join(bars)}
    </svg>
    """
    return svg_card(title, svg, f'<div class="legend-row">{interactive_legend or legend}</div>')


def build_histogram(values: list[float], bins: int, title: str, color: str = CHART_COLORS["slate"]) -> str:
    if not values:
        return svg_card(title, "<p>Sem dados disponíveis.</p>")

    minimum = min(values)
    maximum = max(values)
    span = max(maximum - minimum, 1)
    bin_width = math.ceil(span / bins)
    edges = [minimum + bin_width * idx for idx in range(bins)]
    counts = [0] * bins

    for value in values:
        index = min(int((value - minimum) / bin_width), bins - 1)
        counts[index] += 1

    labels = [f"{int(edge)}-{int(edge + bin_width - 1)}" for edge in edges]
    width = 860
    height = 360
    margin_left = 72
    margin_right = 24
    margin_top = 28
    margin_bottom = 72
    plot_width = width - margin_left - margin_right
    plot_height = height - margin_top - margin_bottom
    max_count = max(counts) if counts else 1
    bar_gap = 10
    bar_width = (plot_width - bar_gap * max(len(counts) - 1, 0)) / max(len(counts), 1)

    bars = []
    for idx, (label, count) in enumerate(zip(labels, counts)):
        x = margin_left + idx * (bar_width + bar_gap)
        bar_height = (count / max_count) * (plot_height - 12)
        y = margin_top + plot_height - bar_height
        tooltip = escape_attr(f"{label} dias: {count} oportunidade(s)")
        bars.append(
            f"""
            <rect x="{x:.1f}" y="{y:.1f}" width="{bar_width:.1f}" height="{bar_height:.1f}" rx="7" fill="{color}" class="interactive-shape" data-tooltip="{tooltip}" />
            <text x="{x + bar_width / 2:.1f}" y="{margin_top + plot_height + 24}" text-anchor="middle" class="axis-label small">{html.escape(label)}</text>
            <text x="{x + bar_width / 2:.1f}" y="{y - 8:.1f}" text-anchor="middle" class="value-label">{count}</text>
            """
        )

    svg = f"""
    <svg viewBox="0 0 {width} {height}" class="chart-svg" role="img" aria-label="{html.escape(title)}">
      <line x1="{margin_left}" y1="{margin_top + plot_height}" x2="{width - margin_right}" y2="{margin_top + plot_height}" class="axis-line" />
      {''.join(bars)}
    </svg>
    """
    return svg_card(title, svg)


def dataframe_to_table(df: pd.DataFrame, money_columns: set[str] | None = None) -> str:
    money_columns = money_columns or set()
    headers = "".join(f"<th>{html.escape(str(column))}</th>" for column in df.columns)
    rows = []
    for _, row in df.iterrows():
        cells = []
        tooltip_parts = []
        for column, value in row.items():
            if pd.isna(value):
                rendered = "—"
            elif column in money_columns:
                rendered = format_currency(float(value))
            elif isinstance(value, pd.Timestamp):
                rendered = value.strftime("%d/%m/%Y")
            else:
                rendered = html.escape(str(value))
            cells.append(f"<td>{rendered}</td>")
            tooltip_parts.append(f"{column}: {rendered}")
        rows.append(f'<tr class="interactive-row" data-tooltip="{escape_attr(" | ".join(tooltip_parts))}">{"".join(cells)}</tr>')
    return f'<div class="table-wrap"><table><thead><tr>{headers}</tr></thead><tbody>{"".join(rows)}</tbody></table></div>'


