def prepare_data() -> pd.DataFrame:
    deals = pd.read_excel(INPUT_FILE, sheet_name="deals_unicos")
    deals["Close_Date"] = pd.to_datetime(deals["Close_Date"], errors="coerce")
    deals["Created_Date"] = pd.to_datetime(deals["Created_Date"], errors="coerce")
    deals["Cycle_Days"] = (deals["Close_Date"] - deals["Created_Date"]).dt.days
    deals["Age_Days"] = (REPORT_DATE - deals["Created_Date"]).dt.days
    deals["Close_Month"] = deals["Close_Date"].dt.to_period("M").astype(str)
    deals["Business_Bucket"] = deals["Type"].map(
        lambda value: "Upsell" if value == "Change Order/Upsell" else "New Business"
    )
    return deals


