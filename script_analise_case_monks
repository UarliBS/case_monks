        value_formatter=format_percent,
        tick_formatter=format_percent,
    )
    note_4 = (
        f"Customer Success tem o melhor win rate da base, com {format_percent(win_rate.max())}. "
        f"Event ainda não converteu nenhum deal na base corrigida."
