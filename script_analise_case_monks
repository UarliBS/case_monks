def format_currency(value: float) -> str:
    formatted = f"{float(value):,.2f}"
    return "R$ " + formatted.replace(",", "X").replace(".", ",").replace("X", ".")


def format_number(value: float, decimals: int = 0) -> str:
    formatted = f"{float(value):,.{decimals}f}"
    return formatted.replace(",", "X").replace(".", ",").replace("X", ".")


def format_percent(value: float) -> str:
    return f"{value:.1f}%".replace(".", ",")


def escape(value: object) -> str:
    if pd.isna(value):
        return "—"
    if isinstance(value, pd.Timestamp):
        return value.strftime("%d/%m/%Y")
    return html.escape(str(value))


def escape_attr(value: object) -> str:
    return html.escape(str(value), quote=True)


def svg_card(title: str, svg_content: str, legend_html: str = "") -> str:
    return f"""
    <div class="viz-frame interactive-card2">
      <div class="viz-title">{html.escape(title)}</div>
      {svg_content}
      {legend_html}
    </div>
    """


def build_bar_chart(
    labels: list[str],
    values: list[float],
    title: str,
    color: str = CHART_COLORS["teal"],
    value_formatter=None,
    tick_formatter=None,
) -> str:
    width = 860
    height = 360
    margin_left = 72
    margin_right = 24
    margin_top = 28
    margin_bottom = 64
    plot_width = width - margin_left - margin_right
    plot_height = height - margin_top - margin_bottom
    max_value = max(values) if values else 0
    max_value = max_value if max_value > 0 else 1
    bar_gap = 14
    bar_width = (plot_width - bar_gap * max(len(values) - 1, 0)) / max(len(values), 1)
    value_formatter = value_formatter or format_currency
    tick_formatter = tick_formatter or (lambda value: f"{format_number(value / 1_000_000, 1)}M")

    bars = []
    for idx, (label, value) in enumerate(zip(labels, values)):
        x = margin_left + idx * (bar_width + bar_gap)
        bar_height = (value / max_value) * (plot_height - 12)
        y = margin_top + plot_height - bar_height
        tooltip = escape_attr(f"{label}: {value_formatter(value)}")
        bars.append(
            f"""
            <rect x="{x:.1f}" y="{y:.1f}" width="{bar_width:.1f}" height="{bar_height:.1f}" rx="8" fill="{color}" class="interactive-shape" data-tooltip="{tooltip}" />
            <text x="{x + bar_width / 2:.1f}" y="{margin_top + plot_height + 24}" text-anchor="middle" class="axis-label">{html.escape(label)}</text>
            <text x="{x + bar_width / 2:.1f}" y="{y - 8:.1f}" text-anchor="middle" class="value-label">{html.escape(value_formatter(value))}</text>
            """
        )

    ticks = []
    for step in range(5):
        tick_value = max_value * (step / 4)
        y = margin_top + plot_height - (tick_value / max_value) * plot_height
        ticks.append(
            f"""
            <line x1="{margin_left}" y1="{y:.1f}" x2="{width - margin_right}" y2="{y:.1f}" class="grid-line" />
            <text x="{margin_left - 10}" y="{y + 4:.1f}" text-anchor="end" class="axis-label">{html.escape(tick_formatter(tick_value))}</text>
            """
        )

    svg = f"""
    <svg viewBox="0 0 {width} {height}" class="chart-svg" role="img" aria-label="{html.escape(title)}">
      {''.join(ticks)}
      <line x1="{margin_left}" y1="{margin_top + plot_height}" x2="{width - margin_right}" y2="{margin_top + plot_height}" class="axis-line" />
      {''.join(bars)}
    </svg>
    """
    return svg_card(title, svg)


def polar_to_cartesian(cx: float, cy: float, radius: float, angle_deg: float) -> tuple[float, float]:
    radians = math.radians(angle_deg)
    return cx + radius * math.cos(radians), cy + radius * math.sin(radians)


def donut_slice_path(cx: float, cy: float, outer_r: float, inner_r: float, start_deg: float, end_deg: float) -> str:
    start_outer = polar_to_cartesian(cx, cy, outer_r, start_deg)
    end_outer = polar_to_cartesian(cx, cy, outer_r, end_deg)
    start_inner = polar_to_cartesian(cx, cy, inner_r, end_deg)
    end_inner = polar_to_cartesian(cx, cy, inner_r, start_deg)
    large_arc = 1 if end_deg - start_deg > 180 else 0
    return (
        f"M {start_outer[0]:.2f} {start_outer[1]:.2f} "
        f"A {outer_r} {outer_r} 0 {large_arc} 1 {end_outer[0]:.2f} {end_outer[1]:.2f} "
        f"L {start_inner[0]:.2f} {start_inner[1]:.2f} "
        f"A {inner_r} {inner_r} 0 {large_arc} 0 {end_inner[0]:.2f} {end_inner[1]:.2f} Z"
    )


def build_donut_chart(labels: list[str], values: list[float], title: str, colors: list[str]) -> str:
    width = 860
    height = 360
    cx = 200
    cy = 180
    outer_r = 118
    inner_r = 62
    total = sum(values) if values else 1
    start = -90
    slices = []
    legend_rows = []

    for idx, (label, value) in enumerate(zip(labels, values)):
        angle = (value / total) * 360 if total else 0
        end = start + angle
        color = colors[idx % len(colors)]
        tooltip = escape_attr(f"{label}: {format_currency(value)} ({format_percent((value / total) * 100 if total else 0)})")
        slices.append(
            f'<path d="{donut_slice_path(cx, cy, outer_r, inner_r, start, end)}" fill="{color}" class="interactive-shape" data-tooltip="{tooltip}" />'
        )
        legend_rows.append(
            f"""
            <div class="legend-item interactive-card" data-tooltip="{tooltip}">
              <span class="legend-dot" style="background:{color}"></span>
              <span>{html.escape(label)}</span>
              <strong>{html.escape(format_percent((value / total) * 100 if total else 0))}</strong>
            </div>
            """
        )
        start = end

    center = f"""
      <text x="{cx}" y="{cy - 8}" text-anchor="middle" class="donut-center-label">Total</text>
      <text x="{cx}" y="{cy + 20}" text-anchor="middle" class="donut-center-value">{html.escape(format_currency(total))}</text>
    """

    svg = f"""
    <div class="donut-layout">
      <svg viewBox="0 0 {width} {height}" class="chart-svg" role="img" aria-label="{html.escape(title)}">
        {''.join(slices)}
        {center}
      </svg>
      <div class="legend-box">
        {''.join(legend_rows)}
      </div>
    </div>
    """
    return svg_card(title, svg)


