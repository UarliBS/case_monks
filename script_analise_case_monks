    ticket_medio = deals.groupby("Type")["Amount"].mean().reindex(TYPE_ORDER).dropna()
    ticket_chart = build_bar_chart(
        [label.replace("Project - ", "").replace("Change Order/Upsell", "Upsell") for label in ticket_medio.index],
